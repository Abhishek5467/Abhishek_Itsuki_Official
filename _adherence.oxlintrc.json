{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/layout/**",
              "components/portfolio/**",
              "ui_kits/portfolio/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|Sora|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, Sora, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|size|ring|glow|square|status|className|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, alt, size, ring, glow, square, status, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|dot|className|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, dot, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:solid|photon|optic|resonance|signal|lime|neutral)$/]",
        "message": "<Badge> tone must be one of 'solid' | 'photon' | 'optic' | 'resonance' | 'signal' | 'lime' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|href|iconLeft|iconRight|disabled|onClick|type|className|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, href, iconLeft, iconRight, disabled, onClick, type, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|signal)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'signal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|padding|interactive|accent|accentColor|tick|style|className|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, padding, interactive, accent, accentColor, tick, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|glass|outline|sunken)$/]",
        "message": "<Card> variant must be one of 'default' | 'glass' | 'outline' | 'sunken'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> padding must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|align|plain|className|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: children, align, plain, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:start|center|end)$/]",
        "message": "<Divider> align must be one of 'start' | 'center' | 'end'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|href|size|round|ghost|label|onClick|className|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: children, href, size, round, ghost, label, onClick, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Marquee'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|separator|speed|size|gap|reverse|className|key|ref|className|style|children)$/]",
        "message": "<Marquee> doesn't accept that prop. Declared props: items, separator, speed, size, gap, reverse, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|active|onClick|key|ref|className|style|children)$/]",
        "message": "<NavLink> doesn't accept that prop. Declared props: label, href, active, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProjectCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|category|image|imageAlt|tags|href|arrow|className|key|ref|className|style|children)$/]",
        "message": "<ProjectCard> doesn't accept that prop. Declared props: title, description, category, image, imageAlt, tags, href, arrow, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|index|title|description|align|className|key|ref|className|style|children)$/]",
        "message": "<SectionHeading> doesn't accept that prop. Declared props: eyebrow, index, title, description, align, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:start|center)$/]",
        "message": "<SectionHeading> align must be one of 'start' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SkillMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|icon|value|display|tone|className|key|ref|className|style|children)$/]",
        "message": "<SkillMeter> doesn't accept that prop. Declared props: name, icon, value, display, tone, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='SkillMeter'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:photon|optic|resonance|lime)$/]",
        "message": "<SkillMeter> tone must be one of 'photon' | 'optic' | 'resonance' | 'lime'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SocialLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:network|handle|icon|href|color|arrow|className|key|ref|className|style|children)$/]",
        "message": "<SocialLink> doesn't accept that prop. Declared props: network, handle, icon, href, color, arrow, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|unit|label|sub|tone|style|className|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: value, unit, label, sub, tone, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:photon|optic|resonance|signal|lime)$/]",
        "message": "<StatCard> tone must be one of 'photon' | 'optic' | 'resonance' | 'signal' | 'lime'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|prefix|interactive|onClick|className|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, prefix, interactive, onClick, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiltCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|intensity|style|className|key|ref|className|style|children)$/]",
        "message": "<TiltCard> doesn't accept that prop. Declared props: children, intensity, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimelineItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:period|title|org|location|description|children|tone|hollow|className|key|ref|className|style|children)$/]",
        "message": "<TimelineItem> doesn't accept that prop. Declared props: period, title, org, location, description, children, tone, hollow, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimelineItem'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:photon|optic|resonance|signal|lime)$/]",
        "message": "<TimelineItem> tone must be one of 'photon' | 'optic' | 'resonance' | 'signal' | 'lime'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
